          <Parameter ID="SRB" Name-en="SRB Hysteresis Freq. Att. [0.1 Hz]" Name-de="SRB Freq.Hyst. erreicht [0,1 Hz]" Value="3" Description-en="Maximum deviation between the frequency reference and the motor frequency, which defines steady state operation. (factor" Description-de="Maximale Abweichung zwischen Frequenzsollwert und Motorfrequenz, definiert Beharrungszustand. (Werkseinstellung: 0,3 Hz)" Type="UINT" Range="0-5990" ArConfigModified="true"/>
          <Parameter ID="UDL" Name-en="UDL Underload Managmt." Name-de="UDL Unterlast Managem." Value="1" Description-en="Behavior on switching to underload detection. Details see User Manual (factory setting: YES)" Description-de="Verhalten bei Umschaltung auf Unterlasterkennung. Details siehe Anwenderhandbuch (Werkseinstellung: YES)" Type="INT" ArConfigModified="true">
