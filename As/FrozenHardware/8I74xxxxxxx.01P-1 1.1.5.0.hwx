          <Parameter ID="BEN" Name-en="BEN Brake engage freq [0.1 Hz]" Name-de="BEN Freq. Bremsanzug [0,1 Hz]" Value="0" Description-en="Brake engage frequency threshold. Details see User Manual (factory setting: 0 Hz equals AUTO)" Description-de="Schwellwert der Bremsanzugsfrequenz. Details siehe Anwenderhandbuch (Werkseinstellung: 0 Hz entspricht AUTO)" Type="INT" Range="0-100" ArConfigModified="true"/>
          <Parameter ID="TBE" Name-en="TBE Brake engage delay [0.01 s]" Name-de="TBE Verzög. Bremsanzug [0,01 s]" Value="0" Description-en="Time delay before request to engage brake (factory setting: 0 s)" Description-de="Verzögerung vor dem Bremsanzugsbefehl (Werkseinstellung: 0 s)" Type="UINT" Range="0-500" ArConfigModified="true"/>
          <Parameter ID="BET" Name-en="BET Brake engage time [0.01 s]" Name-de="BET Zeit Bremsanzug [0,01 s]" Value="0" Description-en="Brake engage time (brake response time) (factory setting: 0 s)" Description-de="Bremsanzugszeit (Ansprechzeit der Bremse) (Werkseinstellung: 0 s)" Type="UINT" Range="0-500" ArConfigModified="true"/>
          <Parameter ID="BED" Name-en="BED Engage at reversal" Name-de="BED Bremse Drehr. Umk." Value="0" Description-en="Can be used to select whether or not the brake engages on transition to zero speed when the operating direction is rever" Description-de="Wählbar ob die Bremse während des Uebergangs auf Drehzahl Null bei der Umkehrung der Drehrichtung anziehen soll oder nic" Type="INT" ArConfigModified="true">
            <ComboBox>
