          <Parameter ID="LOC" Name-en="LOC Ovld Detection Thr. [1 %]" Name-de="LUN Unterlast Freq.nenn [1 %]" Value="110" Description-en="Overload detection threshold, as a % of the rated motor current. (factory setting: 110 %)" Description-de="überlasterkennungs-Schwellwert, in Prozent des Motornennstroms. (Werkseinstellung: 110 %)" Type="UINT" Range="70-150" ArConfigModified="true"/>
