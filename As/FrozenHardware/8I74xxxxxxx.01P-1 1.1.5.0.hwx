          <Parameter ID="LUN" Name-en="LUN Unld. Thr. Nom. Speed. [1 %]" Name-de="LUN Unterlast Freq.nenn [1 %]" Value="60" Description-en="Underload threshold at rated motor frequency. (factory setting: 60 %)" Description-de="Zeitverzögerung für die Unterlasterkennung. (Werkseinstellung: 60 %)" Type="UINT" Range="20-100" ArConfigModified="true"/>
          <Parameter ID="LUL" Name-en="LUL Unld. Thr. 0. Speed. [1 %]" Name-de="LUL Unterlast Freq.=0 [1 %]" Value="0" Description-en="Underload threshold at zero frequency, as a % of the rated motor torque. (factory setting: 0 %)" Description-de="Schwellwert für Unterlast bei einer Frequenz von Null, in Prozent des Nennmoments. (Werkseinstellung: 0 %)" Type="UINT" Range="0-100" ArConfigModified="true"/>
