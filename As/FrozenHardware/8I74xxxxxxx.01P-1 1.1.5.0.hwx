          <Parameter ID="TDS" Name-en="TDS Pulse overspd delay [0.1 s]" Name-de="TDS Zeit vor Ueberdrehz. [0.1 s]" Value="0" Description-en="Time delay for taking overspeed detected fault into account. (factory setting: 0.0 s)" Description-de="Zeitverzögerung für die Berücksichtigung des erkannten überspannungsfehlers. (Werkseinstellung: 0,0 s)" Type="UINT" Range="0-100" ArConfigModified="true"/>
