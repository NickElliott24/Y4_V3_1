          <Parameter ID="TTR" Name-en="TTR Time to restart [0.01 s]" Name-de="TTR Zeit Wiederanlauf [0,01 s]" Value="0" Description-en="Time between the end of a brake engage sequence and the start of a brake release sequence (factory setting: 0 s)" Description-de="Verzögerung zwischen dem Ende einer Bremsanzugssequenz und dem Beginn einer Bremsabfallsequenz (Werkseinstellung: 0 s)" Type="UINT" Range="0-1500" ArConfigModified="true"/>
          <Parameter ID="BRR" Name-en="BRR Current ramp time [0.01 s]" Name-de="BRR Zeit Rampe Strom [0,01 s]" Value="0" Description-en="Torque current ramp time (increase and decrease) for a current variation (factory setting: 0 s)" Description-de="Zeit der Rampe des Momentenstroms (Anstieg und Abnahme) für eine Stromänderung (Werkseinstellung: 0 s)" Type="UINT" Range="0-500" ArConfigModified="true"/>
