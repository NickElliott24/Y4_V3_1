        <Group ID="Sdc" Visible="false" ArConfigSkip="true">
          <Parameter ID="SdcTaskInit" Value="(* ### BEGIN _AxisName_ ### *)
(* initialize variables *)
_AxisName__HW.DrvIf_Typ := ncSDC_DRVSERVO16;
strcpy( ADR(_AxisName__HW.DrvIf_Name[0]), ADR('_AxisName__DrvIf') );
_AxisName__HW.DiDoIf_Typ := ncSDC_DIDO;
strcpy( ADR(_AxisName__HW.DiDoIf_Name[0]), ADR('_AxisName__DiDoIf') );

(* force variable offset generation *)
_AxisName_.size                      := _AxisName_.size;
_AxisName__DrvIf.iLifeCnt            := _AxisName__DrvIf.iLifeCnt;
_AxisName__DiDoIf.iLifeCntDriveReady := _AxisName__DiDoIf.iLifeCntDriveReady;
_AxisName__ModuleOk                  := _AxisName__ModuleOk;

(* assign your hardware inputs here*)
(*
_AxisName__DiDoIf.iPosHwEnd  := _AxisName__DiDoIf.iPosHwEnd;
_AxisName__DiDoIf.iNegHwEnd  := _AxisName__DiDoIf.iNegHwEnd;
_AxisName__DiDoIf.iReference := _AxisName__DiDoIf.iReference;
*)
(* ### END _AxisName_ ### *)" Type="STRING" Visible="false"/>
          <Parameter ID="SdcTaskCyclic" Value="(* ### BEGIN _AxisName_ ### *)
(* life counter emulation of digital inputs *)
_AxisName__DiDoIf.iLifeCntReference := _AxisName__DiDoIf.iLifeCntReference + 1;
_AxisName__DiDoIf.iLifeCntNegHwEnd  := _AxisName__DiDoIf.iLifeCntNegHwEnd  + 1;
_AxisName__DiDoIf.iLifeCntPosHwEnd  := _AxisName__DiDoIf.iLifeCntPosHwEnd  + 1;
(* ### END _AxisName_ ### *)" Type="STRING" Visible="false"/>
          <Parameter ID="SdcIoMapping" Value="Cyclic#1._AxisName__DrvIf.iLifeCnt AT %IB.&quot;_ModuleName_&quot;.SDC_LifeCnt;
Cyclic#1._AxisName__DrvIf.iDrvOK AT %IX.&quot;_ModuleName_&quot;.ETAD_Input_Bool_02;
Cyclic#1._AxisName__DrvIf.oSetTime AT %QW.&quot;_ModuleName_&quot;.SDC_SetTime;
Cyclic#1._AxisName__DrvIf.oSetPos AT %QW.&quot;_ModuleName_&quot;.LFRD_Output;
Cyclic#1._AxisName__DiDoIf.iLifeCntDriveReady AT %IB.&quot;_ModuleName_&quot;.SDC_LifeCnt;
Cyclic#1._AxisName__DiDoIf.iLifeCntDriveEnable AT %IB.&quot;_ModuleName_&quot;.SDC_LifeCnt;
Cyclic#1._AxisName__DiDoIf.oDriveEnable AT %QX.&quot;_ModuleName_&quot;.CMDD_Output_Bool_00;
Cyclic#1._AxisName__ModuleOk AT %QX.&quot;_ModuleName_&quot;.CMDD_Output_Bool_01;
Cyclic#1._AxisName__ModuleOk AT %QX.&quot;_ModuleName_&quot;.CMDD_Output_Bool_02;
Cyclic#1._AxisName__ModuleOk AT %IX.&quot;_ModuleName_&quot;.ModuleOk;
Cyclic#1._AxisName__DiDoIf.oDriveEnable AT %QX.&quot;_ModuleName_&quot;.CMDD_Output_Bool_03;
Cyclic#1._AxisName__DiDoIf.iDriveReady AT %IX.&quot;_ModuleName_&quot;.ETAD_Input_Bool_02;" Type="STRING" Visible="false"/>
          <Parameter ID="SdcLibrariesToInsert" Value="asstring" Type="STRING" Visible="false"/>
        </Group>
      </Selection>
    </Selector>
