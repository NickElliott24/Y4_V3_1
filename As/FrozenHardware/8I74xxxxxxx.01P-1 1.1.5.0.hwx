          <Parameter ID="FQT" Name-en="FQT Overspd. pulse thd. [1 Hz]" Name-de="FQT Schw. Puls wo RUN [1 Hz]" Value="0" Description-en="Details see User Manual (factory setting: 0 equals NO)" Description-de="Details siehe Anwender Handbuch(Werkseinstellung: 0 entspricht NO)" Type="UINT" Range="0-1000" ArConfigModified="true"/>
          <Parameter ID="TQB" Name-en="TQB Pulse wo Run delay [0.1 s]" Name-de="TQB Zeit Pulse wo Run [0.1 s]" Value="0" Description-en="Time delay for taking brake failure trip into account. (factory setting: 0.0 s)" Description-de="Zeitverzögerung für die Berücksichtigung des Fehlers Bremsdefekt. (Werkseinstellung: 0,0 s)" Type="UINT" Range="0-100" ArConfigModified="true"/>
