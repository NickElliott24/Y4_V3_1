				if (@LUN){if (LUN==60){}else{write(LUN_Output, LUN);}}
				if (@TOL){if (TOL==0){}else{write(TOL_Output, TOL);}}
				if (@ODL){if (ODL==1){}else{write(ODL_Output, ODL);}}
				
				write(CMI_Output_Async, 0);
				
				if (@DO1){if (DO1==0){}else{write(DO1_Output, DO1);}}
				if (@BLC){if (BLC==0){}else{write(BLC_Output, BLC);}}
				if (@LLC){if (LLC==0){}else{write(LLC_Output, LLC);}}
				if (@OCC){if (OCC==0){}else{write(OCC_Output, OCC);}}
				if (@EBO){if (EBO==0){}else{write(EBO_Output, EBO);}}
				if (@TSY){if (TSY==0){}else{write(TSY_Output, TSY);}}
				if (@DCO){if (DCO==0){}else{write(DCO_Output, DCO);}}
				if (@FQT){if (FQT==0){}else{write(FQT_Output, FQT);}}
				if (@RSA){if (RSA==0){}else{write(RSA_Output, RSA);}}
				if (@R2){if (R2==0){}else{write(R2_Output, R2);}}

				write(CMI_Output_Async, 2);
				
			}

			if (SDC_Mode==0){}else{write(SDC_Mode_Output, SDC_Mode);}
		}
    '/>
    <Resource ID="IO"/>
  </HWD>
