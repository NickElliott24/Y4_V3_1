<?AutomationStudio Version="4.2.4.149"?>
<TextGroup xmlns="http://br-automation.co.at/AS/VC/Project" Name="SettingsHelp">
  <Property Name="Description" Value=""/>
  <Property Name="Index" Value="421"/>
  <TextSnippets/>
  <TextLayer LanguageId="en">
    <Text ID="1803511" Value="DISTANCE BETWEEN BACK EDGE OF ROW CLEARING THE END OF LINE SENSOR (S18) AND LEADING EDGE OF NEXT ROW. DISTANCE IS USED TO CREATE A PRESET TIME, SHOWN BELOW DISTANCE IN MILLISECONDS, BASED ON THE WASHER SPEED VALUE. IF THE LEADING EDGE OF THE FOLLOWING ROW MAKES THE END OF LINE SENSOR BEFORE THE DELAY HAS COMPLETED THE ROW WILL BE HELD UNTIL THE DELAY HAS COMPLETED.  "/>
    <Text ID="1803512" Value="VARIABLE DELAYS/SETTINGS. DELAYS AND SETTINGS USED TO ALTER THE OPERATION OF THE MACHINE, INCLUDING DELAYS FOR GRINDING, CONVEYOR CONTROL, BATCHING SETTINGS. ONLY AVAILABLE WHEN THE PASSWORD LEVEL IS GREATER THAN 'OPERATOR'"/>
    <Text ID="1803513" Value="SERVO MOTOR SPEEDS AND SEEK AND FIND VARIABLES. ONLY AVAILABLE WITH THE 'ENGINEER ' PASSWORD LEVEL."/>
    <Text ID="1803514" Value="SYSTEM VARIABLES. DELAYS FOR AUTO START SEQUENCE.VALUES FOR COMPARATORS FOR FLIP UP ARMS. WATER SYSTEM DELAYS. ONLY AVAILABLE WITH THE 'ENGINEER' PASSWORD LEVEL."/>
    <Text ID="1803515" Value="DELAY FROM GLASS MAKING SENSOR S14, TO ROW BUILDING CONVEYOR STARTING. CAN BE VARIED TO ADJUST PHYSICAL GAP BETWEEN LITES IN ROW."/>
    <Text ID="1803516" Value="MAXIMUM ROW WIDTH. SYSTEM WILL CALCULATE WHEN NO MORE GLASS WILL FIT INTO THE ROW."/>
    <Text ID="1803517" Value="ACTUAL GAP SIZE. ONCE THE DELAYS HAVE BEEN SET, INPUT THE ACTUAL GAP ACHIEVED. THIS IS REQUIRED TO ACHIEVE CORRECT ROW SIZES. "/>
    <Text ID="1803518" Value="DISTANCE FROM CRB STOP SENSOR (S17) TO CENTRELINE OF THE FOLLOWING WASHER. USED TO CALCULATE DELAY FOR POSITIONING THE ROW IN THE CENTRE OF THE CONVEYOR."/>
    <Text ID="1803519" Value="DELAYS FOR TIMEOUT MONITORING OF THE AUTOMATIC SEQUENCING. ALL DELAYS ARE SET LONGER THAN MAXIMUM TIME TAKEN FOR EACH STEP TO COMPLETE. THIS AIDS IN DIAGNOSIS IF A PROBLEM SHOULD OCCUR."/>
    <Text ID="1803520" Value="LINE SPEED SETTINGS FOR DIFFERENT SPEED SETTINGS. PLEASE NOTE, CHANGING THE VALUES DOES NOT CHANGE THE ACTUAL LINE SPEED. THE VALUE IS USED INTERNALLY FOR REFERENCE ONLY. HAVING THE CORRECT VALUES WILL MAKE THE INFORMATION VALUES CORRECT."/>
    <Text ID="1803521" Value="DELAY TO ALLOW GLASS TO BE COMPLETELY STOPPED BEFORE THE LASER MARK IS TRIGGERED. ENSURES NO DISTORTION OF THE MARK."/>
    <Text ID="1803522" Value="TOUCH NAME FOR HELP TEXT:"/>
    <Text ID="1803523" Value="DURING 10-5. DELAY FOR GLASS TO CLEAR THE DATUM GATE, ON CONVEYOR 3 BELTS, CC1."/>
    <Text ID="1803524" Value="DURING 40-5. DELAY BEFORE LOAD BUILDING CONVEYOR, CLB, STARTS AFTER THE LEADING EDGE OF THE ROW MAKES THE LOAD BUILDING START SENSOR, S17. CAN BE USED TO VARY THE GAP BETWEEN ROWS DURING LOAD BUILDING."/>
    <Text ID="1803525" Value="DURING 40-7. DELAY TO ALLOW ROW TO POSITION ON LOAD BUILDING CONVEYOR, CLB, AFTER THE BACK EDGE OF THE ROW HAS CLEARED THE LOAD BUILDING SENSOR, S17."/>
    <Text ID="1803526" Value="DURING 70-1. DELAY TO ALLOW COMPLETE BATCHED LOAD TO CLEAR THE LOAD BUILDING CONVEYOR, CLB, WHEN THE WASHER IS READY TO RECEIVE THE LOAD. DISPLAYED VALUE IS CALCULATED FOR A 10M/MIN SPEED. DELAY WILL AUTO ADJUST FOR ACTUAL CONVEYOR SPEED."/>
    <Text ID="1803527" Value="DURING 82-2. DELAY TO ALLOW THE LOAD BUILDING CONVEYOR TO CONTINUE AFTER THE BACK EDGE OF GLASS HAS CLEARED THE END OF LINE SENSOR, S21, DURING OFFLINE LOADING. DELAY WILL AUTO ADJUST FOR ACTUAL CONVEYOR SPEED."/>
    <Text ID="1803528" Value="DELAY FROM GLASS CLEARING SENSOR S4 TO THE SOLENOID, FOR THE GRINDING BELT PUSH ON, TO BE OFF. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803529" Value="DELAY FOR BUZZER TO SOUND WHEN CONTROL ON BUTTON IS PRESSED. REQUIRES ALL GUARD DOORS TO BE CLOSED AND ESTOP BUTTONS TO BE RESET."/>
    <Text ID="1803530" Value="DELAY BEFORE SYSTEM STANDBY WHEN LINE IS EMPTY. CONTROL CIRCUIT WILL SHUT DOWN AND ALL MOTORS STOP. SET IN MINUTES TO PRECISION OF 1MIN"/>
    <Text ID="1803531" Value="SPEED THAT THE MOVING SEAMER MOVES AT WHEN THE SEARCH DISTANCE IS GREATER THAN 300 MM. MAXIMUM IS 60 M/MIN."/>
    <Text ID="1803532" Value="SPEED THAT THE MOVING SEAMER MOVES AT WHEN THE SEARCH DISTANCE IS LESS THAN 300 MM. MAXIMUM IS 20 M/MIN."/>
    <Text ID="1803533" Value="SPEED THAT THE MOVING SEAMER MOVES AT TO DOUBLE CHECK THE EDGE POSITION OF THE GLASS. MAXIMUM IS 5 M/MIN. ALTERING THIS VALUE WILL AFFECT THE ACCURACY OF THE POSITIONING."/>
    <Text ID="1803534" Value="INITIAL COMMAND DISTANCE FOR MOVING SEAMER TO MOVE WHEN MOVING AT THE SLOW SEARCH SPEED."/>
    <Text ID="1803535" Value="INITIAL COMMAND DISTANCE FOR MOVING SEAMER TO MOVE WHEN MOVING AT THE SLOW CHECK SPEED."/>
    <Text ID="1803536" Value="DISTANCE TO POSITION MOVING SEAMER AFTER GLASS EDGE DETECTION WHEN PERFORMING A SLOW REVERSE SEARCH."/>
    <Text ID="1803537" Value="DISTANCE TO POSITION MOVING SEAMER AFTER GLASS EDGE DETECTION WHEN PERFORMING A SLOW FORWARD SEARCH."/>
    <Text ID="1803538" Value="DISTANCE TO POSITION MOVING SEAMER AFTER GLASS EDGE DETECTION WHEN PERFORMING A SLOW CHECK SEARCH."/>
    <Text ID="1803539" Value="CAN NOT BE ALTERED!"/>
    <Text ID="1803540" Value="CAN NOT BE ALTERED!"/>
    <Text ID="1803541" Value="POSITION LESS THAN 300 MM FROM THE MAXIMUM LIMIT OF TRAVEL. DETERMINES POSITION THAT MOVING SEAMER GOES TOO DURING A FAST FORWARD SEARCH."/>
    <Text ID="1803542" Value="POSITION LESS THAN 300 MM FROM THE MINIMUM LIMIT OF TRAVEL. DETERMINES POSITION THAT MOVING SEAMER GOES TOO DURING A FAST REVERSE SEARCH."/>
    <Text ID="1803543" Value="HOME POSITION VALUE THAT IS SET WHEN THE MOVING SEAMER PERFORMS AN ORIGIN SEARCH, EITHER AT MACHINE START UP OR FROM THE TEST SCREEN."/>
    <Text ID="1803544" Value="DISTANCE FROM SENSORS SEEING EDGE OF THE GLASS TO STOPPING, DURING A FAST REVERSE SEARCH. THE STOP POSITION SHOULD BE BETWEEN THE TWO CENTRE SENSORS."/>
    <Text ID="1803545" Value="DELAY FROM GLASS MAKING SENSOR S10 TO THE SOLENOID, FOR THE GRINDING BELT PUSH ON, TO BE ON. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803546" Value="DELAY FROM GLASS CLEARING SENSOR S10 TO THE SOLENOID, FOR THE GRINDING BELT PUSH ON, TO BE OFF. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803547" Value="DELAY FROM GLASS MAKING SENSOR S4 TO THE SOLENOID, FOR THE EDGE DELETION, TO LOWER THE MOTOR. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803548" Value="DELAY FROM GLASS CLEARING SENSOR S4 TO THE SOLENOID, FOR THE EDGE DELETION, TO RAISE THE MOTOR. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803549" Value="DELAY FROM GLASS MAKING SENSOR S10 TO THE SOLENOID, FOR THE EDGE DELETION, TO LOWER THE MOTOR. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803550" Value="DELAY FROM GLASS CLEARING SENSOR S10 TO THE SOLENOID, FOR THE EDGE DELETION, TO RAISE THE MOTOR. PLEASE NOTE ALTERING THE FLOW REGULATORS ON THE ACTUATORS WILL AFFECT THE TIMINGS. "/>
    <Text ID="1803551" Value="DISTANCE FROM SENSORS SEEING EDGE OF THE GLASS TO STOPPING, DURING A FAST FORWARD SEARCH. THE STOP POSITION SHOULD BE BETWEEN THE TWO CENTRE SENSORS."/>
    <Text ID="1803552" Value="FAST SPEED TO MOVE BETWEEN POSITION 1, IN LINE WITH WASHER, AND POSITION 2, IN LINE WITH FURNACE. SPEED IS M/MIN ALONG TIMING BELT. MAXIMUM IS 60M/MIN."/>
    <Text ID="1803553" Value="SLOW SPEED WHEN MOVING FROM ORIGIN TO POSITION TO POSITION 1, IN LINE WITH WASHER, AND AFTER AN ESTOP RECOVERY. SPEED IS M/MIN ALONG TIMING BELT. MAXIMUM IS 20M/MIN."/>
    <Text ID="1803554" Value="POSITION IN MM, ALONG TIMING BELT, WHERE CONVEYOR IS LINE WITH WASHER TO RECEIVE ROWS. "/>
    <Text ID="1803555" Value="POSITION IN MM, ALONG TIMING BELT, WHERE CONVEYOR IS LINE WITH SEAMER 2 TO SEND GLASS. "/>
    <Text ID="1803556" Value="HOME POSITION VALUE THAT IS SET WHEN THE ROTATION CONVEYOR PERFORMS AN ORIGIN SEARCH, EITHER AT MACHINE START UP OR FROM THE TEST SCREEN."/>
    <Text ID="1803557" Value="POSITION IN MM, ALONG TIMING BELT, WHERE THE RESTART DELAY, BEFORE RETURNING TO POSITION 1, IS STARTED. MUST BE SET TO ALLOW LEADING EDGE OF FOLLOWING GLASS TO REACH THE END OF SEAMER 1 CONVEYOR AS POSITION 1 IS REACHED."/>
    <Text ID="1803558" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN SEAMING GLASS. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803559" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN TRANSFERRING GLASS BETWEEN SEAMING. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803560" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN TRANSFERRING GLASS BETWEEN SEAMING ALONG THE FULL LENGTH OF A CONVEYOR. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803561" Value="DURING AUTO START SEQUENCE, FROM THE GRINDING TAB, TIME BEFORE BELT MOTOR STARTS."/>
    <Text ID="1803562" Value="DURING AUTO START SEQUENCE, FROM THE GRINDING TAB, TIME BEFORE VACUUM PUMP STARTS."/>
    <Text ID="1803563" Value="DELAY FOR FLOAT SWITCHES TO BE OFF, DETECTING LOW WATER, BEFORE THE WATER TANK PUMPS STOP. "/>
    <Text ID="1803564" Value="POSITION OF MOVING SEAMER TO ALLOW THE FIRST PAIR OF FLIP UP ARMS TO RAISE."/>
    <Text ID="1803565" Value="POSITION OF MOVING SEAMER TO ALLOW THE SECOND PAIR OF FLIP UP ARMS TO RAISE."/>
    <Text ID="1803566" Value="POSITION OF MOVING SEAMER TO ALLOW THE THIRD PAIR OF FLIP UP ARMS TO RAISE."/>
    <Text ID="1803567" Value="POSITION OF MOVING SEAMER TO ALLOW THE FOURTH PAIR OF FLIP UP ARMS TO RAISE."/>
    <Text ID="1803568" Value="POSITION OF MOVING SEAMER TO ALLOW THE FIFTH PAIR OF FLIP UP ARMS TO RAISE."/>
    <Text ID="1803569" Value="DELAY FROM THE START OF THE GRINDING BELTS AUTO START SEQUENCE, TO THE SCAVENGE PUMPS BEING ON."/>
    <Text ID="1803570" Value="DELAY  TO ALLOW WATER TO BE PUMPED OUT OF COLLECTION TRAYS, FROM WHEN THE GRINDING BELTS ARE STOPPED."/>
    <Text ID="1803571" Value="TIME THAT FLOAT SWITCH IN THE EVACUATION CHAMBER HAS TO BE ON BEFORE THE PUMP EMPTIES THE WATER. IF THE PUMP IS ON ALL THE TIME CHECK THAT THE FLOAT SWITCH IS WORKING."/>
    <Text ID="1803572" Value="TIME THAT FLOAT SWITCH IN THE WATER TANK HAS TO BE OFF BEFORE THE PUMP STOPS. TO STOP THE PUMP RUNNING DRY."/>
    <Text ID="1803573" Value="AFTER A CONTROL STOP OF THE LINE. ALLOWS THE VACUUM PUMPS TO RUN FOR THIS TIME TO PULL DRY AIR THROUGH THE PUMPS. IMPORTANT TO DO THIS DAILY."/>
    <Text ID="1803574" Value="DELAY BEFORE SEAMING CONVEYOR CAN START AFTER AN ESTOP RCOVERY. ALLOWS TIME FOR THE GRINDING BELTS TO BE PUSHED ONTO THE EDGE OF THE GLASS, IF NEEDED."/>
    <Text ID="1803575" Value="TIME THAT FILSTAR VALVE IS OPEN TO CLEAR OUT SEDIMENT."/>
    <Text ID="1803576" Value="TIME BETWEEN FILSTAR VALVE OPENING."/>
    <Text ID="1803577" Value="TIMEOUT DELAYS FOR MONITORING IF GLASS IS REACHING NEXT POSITION. DELAYS TO BE SET LONGER THAN MINIMUM OR MAXIMUM SIZE TAKES TO CLEAR CURRENT TRACKING SECTION, INDICATED BY TRACKING NUMBER. IF THE DELAY TIMES OUT THEN A WARNING WILL BE RAISED. TO CONTINUE RUNNING, NAVIGATE TO THE WARNING SCREEN TO ACKNOWLEDGE TIMEOUT."/>
    <Text ID="1803578" Value="DELAY FROM ROW EXIT CONVEYOR STARTING BEFORE LOAD BUILDING CONVEYOR STARTING. CAN BE VARIED TO ADJUST PHYSICAL GAP BETWEEN ROWS IN LOAD."/>
    <Text ID="1803579" Value="DELAY FROM TRAILING EDGE OF ROW CLEARING LOAD BUILDING SENSOR (S18) TO CONVEYOR STOPPING. CAN BE VARIED TO ADJUST PHYSICAL GAP BETWEEN ROWS."/>
    <Text ID="1803580" Value="DELAY FOR COMPLETE LOAD TO CLEAR THE LOAD BUILDING CONVEYOR. MUST BE ALTERED TO SUIT THE SPEED OF THE FOLLOWING EQUIPMENT."/>
    <Text ID="1803581" Value="MAXIMUM LOAD LENGTH. SYSTEM WILL CALCULATE WHEN NO MORE ROWS WILL FIT INTO THE LOAD."/>
    <Text ID="1803582" Value="ACTUAL GAP SIZE. ONCE THE DELAYS HAVE BEEN SET, INPUT THE ACTUAL GAP ACHIEVED. THIS IS REQUIRED TO ACHIEVE CORRECT LOAD SIZES. "/>
    <Text ID="1803583" Value="DELAY FOR FULL BATCH SIZE TO MOVE FROM OFFLINE LOADING, MANUAL BATCHING, CONVEYOR TO THE CONVEYOR BEFORE THE WASHER. MUST BE SET TO ALLOW THE FULL BATCH TO BE CLEAR OF THE OFFLINE LOADING CONEVOYR."/>
    <Text ID="1803584" Value="TOLERANCE VALUE FOR CALCULATING WHEN THE AUTO LID HEIGHT ADJUSTMENT IS WITHIN A SUITABLE TOLERANCE TO STOP ACCURATELY AT THE TARGET POSITION."/>
    <Text ID="1803585" Value="OFFSET VALUE FOR CALIBRATION OF THE LID HEIGHT DETECTING LINEAR TRANSDUCER. USE THIS VALUE TO ENSURE THE VALUE MATCHES THE VALUE DISPLAYED ON THE WASHER PANEL."/>
    <Text ID="1803586" Value="INPUT ACTUAL SPEED OF THE WASHER TRANSPORT FOR DIFFERENT PRESET SPEEDS. SP2 = 4MM, SP3 = 6MM, SP4 = 8MM, SP5 = 10MM, SP6 = 12MM."/>
    <Text ID="1803587" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN SQUARING OR POSITIONING GLASS AGAINST A DATUM, EITHER FORWARD OR REVERSE. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803588" Value="SELECTION OF FURNACE CLEAR INPUT CONFIGURATION. USE THE DROP DOWN BOX TO SELECT BETWEEN A PULSE SIGNAL, OR ON SIGNAL."/>
    <Text ID="1803589" Value="DELAY FOR COMPLETE LOAD TO CLEAR THE WASHER RUNOUT CONVEYOR. MUST BE ALTERED TO SUIT THE SPEED OF THE FURNACE CONVEYOR."/>
    <Text ID="1803590" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN POSITIONING GLASS FOR A LASER MARK. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803591" Value="SET THE ACTUAL SPEED OF THE CONVEYORS TO MATCH THE SPEED OF A WASHING MACHINE. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803592" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN CENTERING GLASS ON THE ROW BUILDING CONVEYOR. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803593" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN BATCHING GLASS ON THE ROW EXIT CONVEYOR. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803594" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN CLEARING THE ROW BUILDING CONVEYOR. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803595" Value="SET THE ACTUAL SPEED OF THE CONVEYORS WHEN MANUALLY LOADING. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803596" Value="MOTOR AND INVERTER VARIABLES. SETUP OF MOTOR AND INVERTER PARAMETERS. USED TO SET MOTOR RATINGS, CONVEYOR SPEEDS, ACCELERATION AND DECELERATION. ONLY AVAILABLE WITH THE 'ENGINEER' LEVEL PASSWORD."/>
    <Text ID="1803597" Value="INPUT THE MOTOR RATED POWER FROM THE MOTOR RATING PLATE, IN KW."/>
    <Text ID="1803598" Value=" INPUT THE MOTOR RATED CURRENT, FROM THE MOTOR RATING PLATE, IN A."/>
    <Text ID="1803599" Value="INPUT THE MOTOR RATED SPEED, FROM THE THE MOTOR RATING PLATE, IN RPM."/>
    <Text ID="1803600" Value="INPUT THE COS PHI VALUE, FROM THE MOTOR RATING PLATE."/>
    <Text ID="1803601" Value="VALUES SHOULD BE SIMILAR TO THE FOLLOWING LIST, ALTER AS REQUIRED:"/>
    <Text ID="1803602" Value="ROLLER CONVEYOR"/>
    <Text ID="1803603" Value="ROLLER CONVEYOR WITH BLOWER"/>
    <Text ID="1803604" Value="BELT RUNNER CONVEYOR"/>
    <Text ID="1803605" Value="VACUUM BELT CONVEYOR"/>
    <Text ID="1803606" Value="2.20 KW"/>
    <Text ID="1803607" Value="8.0 A"/>
    <Text ID="1803608" Value="2870 RPM"/>
    <Text ID="1803609" Value="0.83"/>
    <Text ID="1803610" Value="2.20 KW"/>
    <Text ID="1803611" Value="8.0 A"/>
    <Text ID="1803612" Value="2790 RPM"/>
    <Text ID="1803613" Value="0.79"/>
    <Text ID="1803614" Value="2.20 KW"/>
    <Text ID="1803615" Value="8.6 A"/>
    <Text ID="1803616" Value="1420 RPM"/>
    <Text ID="1803617" Value="0.76"/>
    <Text ID="1803618" Value="2.20 KW"/>
    <Text ID="1803619" Value="8.0 A"/>
    <Text ID="1803620" Value="2772 RPM"/>
    <Text ID="1803621" Value="0.85"/>
    <Text ID="1803622" Value="SHOULD ONLY BE CHANGED IF THE MOTOR IS CHANGED FOR ANY REASON."/>
    <Text ID="1803623" Value="USED TO SCALE THE SET SPEEDS TO THE ACTUAL SPEEDS. SET THE ACTUAL SPEED OF THE CONVEYOR AT 50HZ. ONLY AVAILABLE WITH 'ENGINEER' LEVEL PASSWORD. SETTING ALSO AVAILABLE ON DRIVE TEST SCREENS FOR SETUP."/>
    <Text ID="1803624" Value="ACCELERATION PARAMETER OF INVERTER. DEFAULT VALUE IS 0.5S. ONLY CHANGE IF ABSOLUTELY NECESSARY. ONLY AVAILABLE WITH 'ENGINEER' LEVEL PASSWORD. SETTING ALSO AVAILABLE ON DRIVE TEST SCREENS FOR SETUP."/>
    <Text ID="1803625" Value="DECELERATION PARAMETER OF INVERTER. DEFAULT VALUE IS 0.5S. ONLY CHANGE IF ABSOLUTELY NECESSARY. ONLY AVAILABLE WITH 'ENGINEER' LEVEL PASSWORD. SETTING ALSO AVAILABLE ON DRIVE TEST SCREENS FOR SETUP."/>
    <Text ID="1803626" Value="FREQUENCY VALUE FOR TILT TABLE LOWERING OR RAISING AT FAST SPEED."/>
    <Text ID="1803627" Value="FREQUENCY VALUE FOR TILT TABLE LOWERING OR RAISING AT SLOW SPEED FOR POSITIONING."/>
    <Text ID="1803628" Value="ACCELERATION PARAMETER OF INVERTER. DEFAULT VALUE IS 0.5S. ONLY CHANGE IF ABSOLUTELY NECESSARY. ONLY AVAILABLE WITH 'ENGINEER' LEVEL PASSWORD. SETTING ALSO AVAILABLE ON DRIVE TEST SCREENS FOR SETUP."/>
    <Text ID="1803629" Value="DECELERATION PARAMETER OF INVERTER. DEFAULT VALUE IS 0.5S. ONLY CHANGE IF ABSOLUTELY NECESSARY. ONLY AVAILABLE WITH 'ENGINEER' LEVEL PASSWORD. SETTING ALSO AVAILABLE ON DRIVE TEST SCREENS FOR SETUP."/>
    <Text ID="1803630" Value="53.49 M/MIN"/>
    <Text ID="1803631" Value="DURING 30-5. DELAY TO ALLOW GLASS TO POSITION ON ROW BUILDING CONVEYOR, CRB, AFTER THE BACK EDGE CLEAR THE ROW BUILDING STOP SENSOR, S15."/>
    <Text ID="1803632" Value="SET THE ACTUAL SPEED OF THE CONVEYORS TO MATCH EQUIPMENT USED TO AUTOMATICALLY UNLOAD. USED TO ALTER THE ACTUAL LINE SPEED."/>
    <Text ID="1803633" Value="DURING 10-7. DELAY FOR GLASS TO SQUARE AGAINST THE  DATUM GATE, WHILE REVERSING, ON CONVEYOR  3 BELTS, CC1."/>
    <Text ID="1803634" Value="SELECTION OF ANALOG INPUT TYPE. CAN CHOOSE BETWEEN ONE VOLTAGE AND TWO CURRENT TYPES. RELEVANT CONVEYORS WILL FOLLOW THE SPEEDS OF ANALOG REFERENCE WHEN REQUIRED. "/>
    <Text ID="1803635" Value="DURING 41-1. DELAY BEFORE ROW BUILDING CONVEYOR, CRB, STARTS. CAN BE USED TO VARY THE GAP BETWEEN LITES DURING ROW BUILDING."/>
    <Text ID="1803636" Value="DELAY TO ALLOW GLASS, IN MANUAL BATCHING MODE, TO CLEAR THE COMPLETE BATCH INTO THE WASHER."/>
    <Text ID="1803637" Value="DISPLAYS RAW VALUE OF ANALOG INPUT. TO SET THE CORRECT SPEED FOR 'FOLLOWING' OF THE ANALOG INPUT, THE SOURCE CONVEYOR MUST BE RUNNING WHEN THE VALUES ARE SAVED."/>
    <Text ID="1803638" Value="WHEN THE SOURCE CONVEYOR FOR 'FOLLOWING' IS RUNNING, MEASURE AND INPUT THE SPEED IN THIS BOX. THIS VALUE AND THE RAW VALUE ESTABLISH THE SCALING FOR SETTING THE SPEED OF THE 'FOLLOWING' CONVEYOR."/>
    <Text ID="1803639" Value="WHEN THE ACTUAL WASHER SPEED VALUE HAS BEEN SET FOR THE RAW ANALOG VALUE, PRESS THE 'SAVE VALUES' BUTTON. THE SAVED VALUES ARE USED TO CORRECTLY SCALE THE SPEED OF THE 'FOLLOWING' CONVEYORS AGAINST THE ANALOG INPUT."/>
    <Text ID="1803640" Value="DELAY FROM GLASS MAKING PROCESS SENSOR, S4, TO THE SOLENOID, FOR THE GRINDING BELT PUSH ON, TO BE ON. ALTERING FLOW REGULATORS ON ACTUATORS WILL AFFECT TIMINGS."/>
    <Text ID="1803641" Value=""/>
    <Text ID="1803642" Value="DELAY FROM GLASS MAKING SENSOR S16 BEFORE THE ROW BUILDING CONVEYOR STARTS. CAN BE USED TO VARY THE GAP SIZE BETWEEN THE GLASS IN THE ROW."/>
    <Text ID="1803643" Value="DISPLAYS THE ACTUAL WASHER SPEED SAVED WHEN THE FOLLOWING SCALING WAS SET."/>
    <Text ID="1803644" Value="DISPLAYS THE ANALOG VALUE SAVED WHEN THE FOLLOWING SCALING WAS SET."/>
    <Text ID="1803645" Value="AFTER A CONTROL STOP OF THE LINE. ALLOWS THE VACUUM PUMPS TO RUN FOR THIS TIME TO PULL AIR THROUGH THE PUMPS. IMPORTANT TO DO DAILY."/>
    <Text ID="1803646" Value="DELAY BEFORE SEAMING CONVEYORS CAN START AFTER AN ESTOP RECOVERY. ALLOWS TIME FOR THE GRINDING BELTS TO BE PUSHED ONTO THE EDGE OF THE GLASS, IF NEEDED."/>
    <Text ID="1803647" Value="DELAY TO ALLOW RESTART OF GLASS BEFORE SEAMER 2, AFTER GLASS STARTS MOVING AFTER SEAMER 2."/>
    <Text ID="1803648" Value="DELAY TO ALLOW BACK EDGE OF GLASS TO CLEAR BUFFER CONVEYOR 1, AFTER TRAILING EDGE OF GLASS CLEARS SENSOR S15."/>
    <Text ID="1803649" Value="DURING 20-6. DELAY TO POSITION THE GLASS AFTER SEAMER 2 TO LINE UP WITH THE FOLLOWING BELT CONVEYORS."/>
    <Text ID="1803650" Value="DURING 20-5. DELAY TO POSITION THE GLASS AFTER SEAMER 2 TO LINE UP WITH THE FOLLOWING BELT CONVEYORS."/>
    <Text ID="1803651" Value="MAXIMUM ROW WIDTH. SYSTEM WILL CALCULATE WHEN NO MORE GLASS WILL FIT INTO THE ROW."/>
    <Text ID="1803652" Value="DELAY FROM ROW CLEARING SENSOR S19 BEFORE THE LOAD BUILDING CONVEYOR STOPS. CAN BE USED TO VARY THE GAP SIZE BETWEEN THE ROWS IN THE LOAD."/>
    <Text ID="1803653" Value="DELAY FROM ROW MAKING SENSOR S19 BEFORE THE LOAD BUILDING CONVEYOR STARTS. CAN BE USED TO VARY THE GAP SIZE BETWEEN THE ROWS IN THE LOAD."/>
    <Text ID="1803654" Value="DELAY BEFORE THE PNEUMATIC SCAVENGE PUMPS START AFTER THE WATER PUMPS START."/>
    <Text ID="1803655" Value="DELAY BEFORE THE PNEUMATIC SCAVENGE PUMPS STOP AFTER THE WATER PUMPS STOP. SHOULD BE SET LONG ENOUGH TO SCAVENGE WATER AFTER A CONTROL STOP."/>
    <Text ID="1803656" Value=""/>
    <Text ID="1803657" Value=""/>
    <Text ID="1803658" Value="DURING 80-2. DELAY TO ALLOW THE OFFLINE LOADED GLASS TO CLEAR THE ROW BUILDING LOAD SENSOR BEFORE STOPPING."/>
  </TextLayer>
