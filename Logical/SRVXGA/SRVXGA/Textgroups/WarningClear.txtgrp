  <TextLayer LanguageId="en">
    <Text ID="1804766" Value="If pallet moved, check position of reed switch. If pallet did not move, check solenoid override switch. Check Air Pressure."/>
    <Text ID="1804767" Value="Waiting for rising edge of photo cell S1. Check lens for dirt or moisture. Adjust warning delay if required."/>
    <Text ID="1804768" Value="Waiting for rising edge of photo cell S2. Check lens for dirt or moisture. Adjust warning delay if required."/>
